// HTTP POST + JSON sum reference for AgentLang Index.
//
// Zero 0.1.2 has no exposed stdin, so URL/a/b come from argv[1..3].
// std.http.fetch is invoked with a POST envelope (method-line + JSON
// content-type header + JSON body). On HTTP 200 we scan the response
// body for `"sum":<digits>` and write that integer + newline. On any
// transport, status, or parse failure we write `error\n`.
//
// The direct backend MVP forbids user functions taking Span<u8>,
// MutSpan<u8>, or returning shape locals, so the i32 parse, envelope
// rendering, response scan, and output rendering are all inline here.

pub fn main(world: World) -> Void raises {
    let maybe_url: Maybe<String> = std.args.get(1)
    let maybe_a: Maybe<String> = std.args.get(2)
    let maybe_b: Maybe<String> = std.args.get(3)
    if maybe_url.has == false {
        check world.out.write("error\n")
        return
    }
    if maybe_a.has == false {
        check world.out.write("error\n")
        return
    }
    if maybe_b.has == false {
        check world.out.write("error\n")
        return
    }

    let url_s: Span<u8> = std.mem.span(maybe_url.value)
    let a_s: Span<u8> = std.mem.span(maybe_a.value)
    let b_s: Span<u8> = std.mem.span(maybe_b.value)

    // ---- Parse a as i32 from trimmed ASCII digits ----
    let a_n: usize = std.mem.len(a_s)
    var a_i: usize = 0
    var a_skip_flag: Bool = true
    while a_skip_flag {
        if a_i >= a_n {
            a_skip_flag = false
        } else {
            let c: u8 = a_s[a_i]
            if c == 32_u8 {
                a_i = a_i + 1
            } else {
                if c == 9_u8 {
                    a_i = a_i + 1
                } else {
                    a_skip_flag = false
                }
            }
        }
    }
    if a_i >= a_n {
        check world.out.write("error\n")
        return
    }
    var a_neg: Bool = false
    if a_s[a_i] == 45_u8 {
        a_neg = true
        a_i = a_i + 1
    }
    if a_i >= a_n {
        check world.out.write("error\n")
        return
    }
    var a_have_digit: Bool = false
    var a_acc: u32 = 0_u32
    var a_digit_flag: Bool = true
    while a_digit_flag {
        if a_i >= a_n {
            a_digit_flag = false
        } else {
            let c: u8 = a_s[a_i]
            if c >= 48_u8 {
                if c <= 57_u8 {
                    let d: u32 = (c - 48_u8) as u32
                    a_acc = a_acc * 10_u32 + d
                    a_have_digit = true
                    a_i = a_i + 1
                } else {
                    a_digit_flag = false
                }
            } else {
                a_digit_flag = false
            }
        }
    }
    var a_tail_flag: Bool = true
    var a_tail_ok: Bool = true
    while a_tail_flag {
        if a_i >= a_n {
            a_tail_flag = false
        } else {
            let c: u8 = a_s[a_i]
            if c == 32_u8 {
                a_i = a_i + 1
            } else {
                if c == 9_u8 {
                    a_i = a_i + 1
                } else {
                    if c == 10_u8 {
                        a_i = a_i + 1
                    } else {
                        if c == 13_u8 {
                            a_i = a_i + 1
                        } else {
                            a_tail_ok = false
                            a_tail_flag = false
                        }
                    }
                }
            }
        }
    }
    if a_tail_ok == false {
        check world.out.write("error\n")
        return
    }
    if a_have_digit == false {
        check world.out.write("error\n")
        return
    }
    if a_acc > 2147483647_u32 {
        check world.out.write("error\n")
        return
    }
    var a_val: i32 = a_acc as i32
    if a_neg {
        a_val = 0_i32 - a_val
    }

    // ---- Parse b as i32 from trimmed ASCII digits ----
    let b_n: usize = std.mem.len(b_s)
    var b_i: usize = 0
    var b_skip_flag: Bool = true
    while b_skip_flag {
        if b_i >= b_n {
            b_skip_flag = false
        } else {
            let c: u8 = b_s[b_i]
            if c == 32_u8 {
                b_i = b_i + 1
            } else {
                if c == 9_u8 {
                    b_i = b_i + 1
                } else {
                    b_skip_flag = false
                }
            }
        }
    }
    if b_i >= b_n {
        check world.out.write("error\n")
        return
    }
    var b_neg: Bool = false
    if b_s[b_i] == 45_u8 {
        b_neg = true
        b_i = b_i + 1
    }
    if b_i >= b_n {
        check world.out.write("error\n")
        return
    }
    var b_have_digit: Bool = false
    var b_acc: u32 = 0_u32
    var b_digit_flag: Bool = true
    while b_digit_flag {
        if b_i >= b_n {
            b_digit_flag = false
        } else {
            let c: u8 = b_s[b_i]
            if c >= 48_u8 {
                if c <= 57_u8 {
                    let d: u32 = (c - 48_u8) as u32
                    b_acc = b_acc * 10_u32 + d
                    b_have_digit = true
                    b_i = b_i + 1
                } else {
                    b_digit_flag = false
                }
            } else {
                b_digit_flag = false
            }
        }
    }
    var b_tail_flag: Bool = true
    var b_tail_ok: Bool = true
    while b_tail_flag {
        if b_i >= b_n {
            b_tail_flag = false
        } else {
            let c: u8 = b_s[b_i]
            if c == 32_u8 {
                b_i = b_i + 1
            } else {
                if c == 9_u8 {
                    b_i = b_i + 1
                } else {
                    if c == 10_u8 {
                        b_i = b_i + 1
                    } else {
                        if c == 13_u8 {
                            b_i = b_i + 1
                        } else {
                            b_tail_ok = false
                            b_tail_flag = false
                        }
                    }
                }
            }
        }
    }
    if b_tail_ok == false {
        check world.out.write("error\n")
        return
    }
    if b_have_digit == false {
        check world.out.write("error\n")
        return
    }
    if b_acc > 2147483647_u32 {
        check world.out.write("error\n")
        return
    }
    var b_val: i32 = b_acc as i32
    if b_neg {
        b_val = 0_i32 - b_val
    }

    // ---- Build POST envelope: POST <url>\n + Content-Type header + body ----
    var envelope: [1024]u8 = [0_u8; 1024]
    var env_n: usize = 0

    let prefix: Span<u8> = std.mem.span("POST ")
    let pre_n: usize = std.mem.len(prefix)
    var pi: usize = 0
    while pi < pre_n {
        envelope[env_n] = prefix[pi]
        env_n = env_n + 1
        pi = pi + 1
    }

    let url_n: usize = std.mem.len(url_s)
    var ui: usize = 0
    var url_flag: Bool = true
    while url_flag {
        if ui >= url_n {
            url_flag = false
        } else {
            let c: u8 = url_s[ui]
            if c == 10_u8 {
                url_flag = false
            } else {
                if c == 13_u8 {
                    url_flag = false
                } else {
                    envelope[env_n] = c
                    env_n = env_n + 1
                    ui = ui + 1
                }
            }
        }
    }
    envelope[env_n] = 10_u8
    env_n = env_n + 1

    let ct: Span<u8> = std.mem.span("Content-Type: application/json\n")
    let ct_n: usize = std.mem.len(ct)
    var ci: usize = 0
    while ci < ct_n {
        envelope[env_n] = ct[ci]
        env_n = env_n + 1
        ci = ci + 1
    }
    envelope[env_n] = 10_u8
    env_n = env_n + 1

    // Body: {"a":<a>,"b":<b>}
    envelope[env_n] = 123_u8
    env_n = env_n + 1
    envelope[env_n] = 34_u8
    env_n = env_n + 1
    envelope[env_n] = 97_u8
    env_n = env_n + 1
    envelope[env_n] = 34_u8
    env_n = env_n + 1
    envelope[env_n] = 58_u8
    env_n = env_n + 1

    // Inline writeI32 for a_val
    var a_write_neg: Bool = false
    var a_write_v: u32 = 0_u32
    if a_val < 0_i32 {
        envelope[env_n] = 45_u8
        env_n = env_n + 1
        a_write_neg = true
        a_write_v = (0_i32 - a_val) as u32
    } else {
        a_write_v = a_val as u32
    }
    if a_write_v == 0_u32 {
        envelope[env_n] = 48_u8
        env_n = env_n + 1
    } else {
        var a_tmp: [16]u8 = [0_u8; 16]
        var a_tn: usize = 0
        while a_write_v > 0_u32 {
            let digit_u32: u32 = 48_u32 + (a_write_v % 10_u32)
            a_tmp[a_tn] = digit_u32 as u8
            a_tn = a_tn + 1
            a_write_v = a_write_v / 10_u32
        }
        var a_wj: usize = 0
        while a_wj < a_tn {
            envelope[env_n] = a_tmp[a_tn - 1 - a_wj]
            env_n = env_n + 1
            a_wj = a_wj + 1
        }
    }

    envelope[env_n] = 44_u8
    env_n = env_n + 1
    envelope[env_n] = 34_u8
    env_n = env_n + 1
    envelope[env_n] = 98_u8
    env_n = env_n + 1
    envelope[env_n] = 34_u8
    env_n = env_n + 1
    envelope[env_n] = 58_u8
    env_n = env_n + 1

    // Inline writeI32 for b_val
    var b_write_neg: Bool = false
    var b_write_v: u32 = 0_u32
    if b_val < 0_i32 {
        envelope[env_n] = 45_u8
        env_n = env_n + 1
        b_write_neg = true
        b_write_v = (0_i32 - b_val) as u32
    } else {
        b_write_v = b_val as u32
    }
    if b_write_v == 0_u32 {
        envelope[env_n] = 48_u8
        env_n = env_n + 1
    } else {
        var b_tmp: [16]u8 = [0_u8; 16]
        var b_tn: usize = 0
        while b_write_v > 0_u32 {
            let digit_u32: u32 = 48_u32 + (b_write_v % 10_u32)
            b_tmp[b_tn] = digit_u32 as u8
            b_tn = b_tn + 1
            b_write_v = b_write_v / 10_u32
        }
        var b_wj: usize = 0
        while b_wj < b_tn {
            envelope[env_n] = b_tmp[b_tn - 1 - b_wj]
            env_n = env_n + 1
            b_wj = b_wj + 1
        }
    }

    envelope[env_n] = 125_u8
    env_n = env_n + 1

    // ---- Fetch ----
    let net: Net = std.net.host()
    let client: HttpClient = std.http.client(net)
    var response: [8192]u8 = [0_u8; 8192]
    let result: HttpResult = std.http.fetch(client, envelope[0..env_n], response, std.time.ms(5000))
    if std.http.resultOk(result) == false {
        check world.out.write("error\n")
        return
    }
    if std.http.resultStatus(result) != 200 {
        check world.out.write("error\n")
        return
    }
    let body_len: usize = std.http.resultBodyLen(result)
    let body_offset: usize = std.http.responseBodyOffset(response)

    // ---- Scan body for `"sum":<digits>` ----
    let needle: Span<u8> = std.mem.span("\"sum\":")
    let needle_n: usize = std.mem.len(needle)
    let end: usize = body_offset + body_len
    if needle_n == 0_usize {
        check world.out.write("error\n")
        return
    }
    if end < needle_n {
        check world.out.write("error\n")
        return
    }
    let stop: usize = end - needle_n
    var found_at: usize = 0_usize
    var found: Bool = false
    var si: usize = body_offset
    var search_flag: Bool = true
    while search_flag {
        if si > stop {
            search_flag = false
        } else {
            var j: usize = 0
            var matched: Bool = true
            var inner_flag: Bool = true
            while inner_flag {
                if j >= needle_n {
                    inner_flag = false
                } else {
                    if response[si + j] != needle[j] {
                        matched = false
                        inner_flag = false
                    } else {
                        j = j + 1
                    }
                }
            }
            if matched {
                found_at = si + needle_n
                found = true
                search_flag = false
            } else {
                si = si + 1
            }
        }
    }
    if found == false {
        check world.out.write("error\n")
        return
    }

    // Parse digits (with optional leading `-`) at found_at.
    var k: usize = found_at
    var k_ws_flag: Bool = true
    while k_ws_flag {
        if k >= end {
            k_ws_flag = false
        } else {
            let c: u8 = response[k]
            if c == 32_u8 {
                k = k + 1
            } else {
                if c == 9_u8 {
                    k = k + 1
                } else {
                    k_ws_flag = false
                }
            }
        }
    }
    if k >= end {
        check world.out.write("error\n")
        return
    }
    var sum_neg: Bool = false
    if response[k] == 45_u8 {
        sum_neg = true
        k = k + 1
    }
    if k >= end {
        check world.out.write("error\n")
        return
    }
    var sum_have_digit: Bool = false
    var sum_acc: u32 = 0_u32
    var sum_digit_flag: Bool = true
    while sum_digit_flag {
        if k >= end {
            sum_digit_flag = false
        } else {
            let c: u8 = response[k]
            if c >= 48_u8 {
                if c <= 57_u8 {
                    let d: u32 = (c - 48_u8) as u32
                    sum_acc = sum_acc * 10_u32 + d
                    sum_have_digit = true
                    k = k + 1
                } else {
                    sum_digit_flag = false
                }
            } else {
                sum_digit_flag = false
            }
        }
    }
    if sum_have_digit == false {
        check world.out.write("error\n")
        return
    }
    // After digits, next byte must be a JSON terminator or end.
    var term_ok: Bool = true
    if k < end {
        let c: u8 = response[k]
        if c == 44_u8 {
            // ok
        } else {
            if c == 125_u8 {
                // ok
            } else {
                if c == 93_u8 {
                    // ok
                } else {
                    if c == 32_u8 {
                        // ok
                    } else {
                        if c == 9_u8 {
                            // ok
                        } else {
                            if c == 10_u8 {
                                // ok
                            } else {
                                if c == 13_u8 {
                                    // ok
                                } else {
                                    term_ok = false
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    if term_ok == false {
        check world.out.write("error\n")
        return
    }
    if sum_acc > 2147483647_u32 {
        check world.out.write("error\n")
        return
    }
    var sum_val: i32 = sum_acc as i32
    if sum_neg {
        sum_val = 0_i32 - sum_val
    }

    // ---- Render sum_val + newline ----
    var out: [16]u8 = [0_u8; 16]
    var out_n: usize = 0
    var out_v: u32 = 0_u32
    if sum_val < 0_i32 {
        out[out_n] = 45_u8
        out_n = out_n + 1
        out_v = (0_i32 - sum_val) as u32
    } else {
        out_v = sum_val as u32
    }
    if out_v == 0_u32 {
        out[out_n] = 48_u8
        out_n = out_n + 1
    } else {
        var out_tmp: [16]u8 = [0_u8; 16]
        var out_tn: usize = 0
        while out_v > 0_u32 {
            let digit_u32: u32 = 48_u32 + (out_v % 10_u32)
            out_tmp[out_tn] = digit_u32 as u8
            out_tn = out_tn + 1
            out_v = out_v / 10_u32
        }
        var out_wj: usize = 0
        while out_wj < out_tn {
            out[out_n] = out_tmp[out_tn - 1 - out_wj]
            out_n = out_n + 1
            out_wj = out_wj + 1
        }
    }
    out[out_n] = 10_u8
    out_n = out_n + 1
    check world.out.write(out[0..out_n])
    return
}
