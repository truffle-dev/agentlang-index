// Count whitespace-separated tokens in input, Zero 0.1.2 direct backend.
//
// argv[1] is the input bytes (Zero 0.1.2 has no exposed stdin capability).
// All logic stays inside `pub fn main` to avoid Span/MutSpan parameter
// restrictions.
//
// One-pass state machine: track `in_word`. Each transition from
// whitespace to non-whitespace increments the count. Whitespace bytes
// are 0x20, 0x09, 0x0A, 0x0D.
//
// Decimal renderer uses small-divisor u32 divmod (avoids the 2^32-
// divisor SIGFPE narrowing-cast bug surfaced in earlier corpus work).
pub fn main(world: World) -> Void raises {
    let line_opt: Maybe<String> = std.args.get(1)
    var bytes: Span<u8> = std.mem.span("")
    if line_opt.has {
        bytes = std.mem.span(line_opt.value)
    }
    let n: usize = std.mem.len(bytes)

    var count: u32 = 0_u32
    var in_word: Bool = false
    var i: usize = 0
    while i < n {
        let b: u8 = bytes[i]
        var is_ws: Bool = false
        if b == 32_u8 {
            is_ws = true
        }
        if b == 9_u8 {
            is_ws = true
        }
        if b == 10_u8 {
            is_ws = true
        }
        if b == 13_u8 {
            is_ws = true
        }
        if is_ws {
            in_word = false
        } else {
            if in_word == false {
                count = count + 1_u32
                in_word = true
            }
        }
        i = i + 1
    }

    var out_buf: [16]u8 = [0_u8; 16]
    var written: usize = 0
    if count == 0_u32 {
        out_buf[0] = 48_u8
        written = 1
    } else {
        var tmp: [16]u8 = [0_u8; 16]
        var tn: usize = 0
        var c: u32 = count
        while c > 0_u32 {
            let d: u32 = c % 10_u32
            tmp[tn] = (48_u32 + d) as u8
            tn = tn + 1
            c = c / 10_u32
        }
        var j: usize = 0
        while j < tn {
            out_buf[j] = tmp[tn - 1 - j]
            j = j + 1
        }
        written = tn
    }
    out_buf[written] = 10_u8
    written = written + 1

    let out: Span<u8> = out_buf[0..written]
    check world.out.write(out)
    return
}
